rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: Is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Get user record from Firestore to check organizationId
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    // Storage path: {orgId}/jobs/{jobId}/{fileName}
    match /{orgId}/jobs/{jobId}/{fileName} {
      // Allow read if user belongs to the same organization
      allow read: if isAuthenticated() && getUserData().organizationId == orgId;
      
      // Allow write (upload/delete) if user belongs to the same organization
      // and it's an image under 5MB with a valid extension
      allow write: if isAuthenticated() 
                   && getUserData().organizationId == orgId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && fileName.matches('.*\\.(jpg|jpeg|png|webp)');
    }

    // Storage path: {orgId}/settings/{fileName} (admin QR codes, logos)
    match /{orgId}/settings/{fileName} {
      allow read: if isAuthenticated() && getUserData().organizationId == orgId;
      allow write: if isAuthenticated() 
                   && getUserData().organizationId == orgId
                   && getUserData().role == 'admin'
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && fileName.matches('.*\\.(jpg|jpeg|png|webp)');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
}
